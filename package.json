{
  "name": "wc-edge-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "vite --port 5180 --strictPort",
    "build": "vite build",
    "preview": "vite preview --port 4180 --strictPort",
    "refresh:data": "cd .. && .venv/bin/python -m wc_model.markets.kalshi_worldcup --limit 25 --log --out frontend/public/kalshi_worldcup.json",
    "refresh:sentiment": "cd .. && .venv/bin/python -m wc_model.markets.kalshi_worldcup --limit 10 --log --sentiment --out frontend/public/kalshi_worldcup.json",
    "rescore": "cd .. && .venv/bin/python -m wc_model.markets.rescore_worldcup --in frontend/public/kalshi_worldcup.json",
    "experiments": "cd .. && .venv/bin/python -m wc_model.model.experiments",
    "refresh:ratings": "cd .. && .venv/bin/python -m wc_model.data.elo --export",
    "backtest:real": "cd .. && .venv/bin/python -m wc_model.backtest.historical"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "vite": "5.4.21"
  }
}
